<!-- 学习设置允许用户决定默认模式、每日新词量和复习目标比例。 -->
<view class="page">
  <text class="section-title">默认学习模式</text>
  <radio-group bindchange="changeMode">
    <label class="option {{settings.defaultMode === 'flashcard' ? 'option-active' : ''}}">
      <view>
        <text class="option-title">单词卡片</text>
        <text class="option-description">先主动回忆，再翻看释义</text>
      </view>
      <radio value="flashcard" checked="{{settings.defaultMode === 'flashcard'}}" color="#5968E8" />
    </label>
    <label class="option {{settings.defaultMode === 'quiz' ? 'option-active' : ''}}">
      <view>
        <text class="option-title">四选一练习</text>
        <text class="option-description">快速检测单词掌握情况</text>
      </view>
      <radio value="quiz" checked="{{settings.defaultMode === 'quiz'}}" color="#5968E8" />
    </label>
  </radio-group>

  <view class="section-heading spacing-top">
    <text class="section-title">每日新词</text>
    <text class="section-value">{{settings.dailyNewWords}} 个</text>
  </view>
  <view class="setting-card">
    <slider min="5" max="500" step="5" value="{{settings.dailyNewWords}}" bindchange="changeDailyNewWords" activeColor="#5968E8" backgroundColor="#d9ddff" block-color="#5968E8" />
    <view class="input-row">
      <text class="option-description">范围 5-500，按 5 的倍数保存</text>
      <input class="number-input" type="number" value="{{settings.dailyNewWords}}" bindblur="inputDailyNewWords" />
    </view>
  </view>

  <view class="section-heading spacing-top">
    <text class="section-title">每日复习</text>
    <text class="section-value">{{reviewTarget}} 个</text>
  </view>
  <radio-group class="ratio-options" bindchange="changeReviewRatio">
    <label class="ratio-option {{settings.reviewRatio === 1 ? 'ratio-active' : ''}}">
      <view>
        <text class="option-title">1:1</text>
        <text class="option-description">复习量等于新词量</text>
      </view>
      <radio value="1" checked="{{settings.reviewRatio === 1}}" color="#5968E8" />
    </label>
    <label class="ratio-option {{settings.reviewRatio === 2 ? 'ratio-active' : ''}}">
      <view>
        <text class="option-title">1:2</text>
        <text class="option-description">默认强度，复习量为新词 2 倍</text>
      </view>
      <radio value="2" checked="{{settings.reviewRatio === 2}}" color="#5968E8" />
    </label>
    <label class="ratio-option {{settings.reviewRatio === 3 ? 'ratio-active' : ''}}">
      <view>
        <text class="option-title">1:3</text>
        <text class="option-description">更重视复习巩固</text>
      </view>
      <radio value="3" checked="{{settings.reviewRatio === 3}}" color="#5968E8" />
    </label>
  </radio-group>
</view>
