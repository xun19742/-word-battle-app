/* 选项卡同时提供文字说明和清晰选中状态，降低设置理解成本。 */
.section-title { display: block; margin: 20rpx 0; font-size: 30rpx; font-weight: 700; }
.spacing-top { margin-top: 52rpx; }
.section-heading { display: flex; align-items: center; justify-content: space-between; }
.section-value { color: #5968e8; font-size: 30rpx; font-weight: 700; }
.option, .ratio-option, .setting-card { padding: 30rpx; margin-bottom: 20rpx; background: #fff; border: 3rpx solid transparent; border-radius: 24rpx; }
.option, .ratio-option { display: flex; align-items: center; justify-content: space-between; }
.option-active, .ratio-active { background: #f1f3ff; border-color: #5968e8; }
.option-title { display: block; font-weight: 700; }
.option-description { display: block; margin-top: 8rpx; color: #718096; font-size: 25rpx; }
.input-row { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; margin-top: 18rpx; }
.number-input { width: 150rpx; padding: 14rpx 18rpx; text-align: center; color: #202853; font-weight: 700; background: #f6f7ff; border-radius: 18rpx; }
.ratio-options { display: grid; gap: 20rpx; }
.ratio-option { margin: 0; }
