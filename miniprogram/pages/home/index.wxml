<!-- 首页展示当前词书、新词计划、复习计划和对应学习入口。 -->
<view class="page">
  <view class="header">
    <view>
      <text class="title">WordRush</text>
      <text class="subtitle">今天也来认识新单词吧</text>
    </view>
    <view class="header-actions">
      <button class="profile-button" bindtap="openProfile">我的</button>
      <button class="settings-button" bindtap="openSettings" aria-label="打开设置">⚙</button>
    </view>
  </view>

  <view wx:if="{{cloudMessage || syncPending}}" class="cloud-banner">
    <text>{{cloudMessage || '有学习记录等待同步，联网后会自动重试'}}</text>
  </view>

  <view class="checkin-card" bindtap="openCheckins">
    <view>
      <text class="eyebrow">{{checkinStats.checkedToday ? '今日已打卡' : '今日未打卡'}}</text>
      <text class="checkin-title">连续 {{checkinStats.streak}} 天</text>
      <text class="muted">今日学习 {{checkinStats.todayCompleted}} 词 · 累计 {{checkinStats.totalDays}} 天</text>
    </view>
    <text class="change-book">记录 ›</text>
  </view>

  <view class="book-picker" bindtap="openWordbooks">
    <view>
      <text class="eyebrow">当前词书</text>
      <text class="book-name">{{bookName}}</text>
      <text class="muted">{{wordCount}} 个单词</text>
    </view>
    <text class="change-book">切换 ›</text>
  </view>

  <view class="plan-grid">
    <view class="plan-card">
      <text class="plan-label">今日新词</text>
      <text class="plan-number">{{newCompleted}} / {{settings.dailyNewWords}}</text>
      <view class="progress-track">
        <view class="progress-value" style="width: {{newProgressPercent}}%;"></view>
      </view>
      <button class="primary-button plan-button" bindtap="startNewWords">学习新词</button>
    </view>

    <view class="plan-card">
      <text class="plan-label">今日复习</text>
      <text class="plan-number">{{reviewCompleted}} / {{reviewTarget}}</text>
      <view class="progress-track">
        <view class="progress-value review-value" style="width: {{reviewProgressPercent}}%;"></view>
      </view>
      <button class="review-button plan-button" bindtap="startReview">今日复习</button>
    </view>
  </view>

  <view class="mode-row">
    <view class="mode-icon">W</view>
    <view class="mode-copy">
      <text class="mode-label">{{modeLabel}}</text>
      <text class="muted">每轮最多 10 词，可在设置中切换模式</text>
    </view>
  </view>

  <button wx:if="{{activeRound}}" class="resume-button" bindtap="resumeLearning">
    继续 {{activeBookName}} 的上次学习
  </button>
  <button class="wrong-button" bindtap="openWrongWords">查看当前词书错词</button>

  <view class="coming-soon">对战模式 · 后续开放</view>
</view>
